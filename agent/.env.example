# Copy this file to `.env` and fill in your values.

# Which model to run, as "<provider>:<model>".
# Default below works if you have an OpenAI key. For exact, current model
# strings (OpenAI, Anthropic, Google, Groq, Ollama, ...) see:
#   https://ai.pydantic.dev/models/
MODEL=openai:gpt-4.1-mini

# Set the key for whichever provider your MODEL uses. Only the matching one is
# needed; leave the others out.
OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here   # if MODEL=anthropic:... (check docs for the model name)
